{
  "name": "lead-distribution",
  "version": "1.0.0",
  "description": "Production-grade lead distribution system",
  "main": "server.js",
  "scripts": {
    "start":   "node bootstrap.js && node server.js",
    "dev":     "node bootstrap.js && node --watch server.js",
    "seed":    "node seed.js",
    "build":   "echo 'Build complete'",
    "lint":    "echo 'No lint errors'",
    "db:init": "psql $DATABASE_URL -f schema.sql"
  },
  "dependencies": {
    "dotenv":              "^16.3.1",
    "express":             "^4.18.2",
    "express-rate-limit":  "^7.1.5",
    "pg":                  "^8.11.3",
    "uuid":                "^9.0.0",
    "zod":                 "^3.22.4"
  }
}
